---
import Logo from './Logo.astro';
---
<nav class="nav">
  <div class="left">
    <a href="/" class="brand">
      <Logo />
      datem
    </a>
    <div class="links">
      <a href="/docs/">docs</a><span>pricing</span><span>customers</span><span>blog</span><span>self-host</span>
    </div>
  </div>
  <div class="right">
    <span class="login">log in</span>
    <span class="signup">sign up</span>
  </div>
</nav>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 40px;
    max-width: 1180px;
    margin: 0 auto;
  }
  .left { display: flex; align-items: center; gap: 36px; }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--dm-font-mono);
    font-weight: 600;
    font-size: 16px;
    letter-spacing: -.04em;
    color: var(--dm-ink);
    text-decoration: none;
  }
  .links {
    display: flex;
    gap: 24px;
    font-family: var(--dm-font-mono);
    font-size: 13.5px;
    color: var(--dm-muted);
    font-weight: 500;
  }
  .links a { color: inherit; text-decoration: none; }
  .right {
    display: flex;
    align-items: center;
    gap: 18px;
    font-family: var(--dm-font-mono);
    font-size: 13.5px;
    font-weight: 500;
  }
  .login { color: var(--dm-muted); }
  .signup {
    background: var(--dm-ink);
    color: var(--dm-paper);
    padding: 8px 15px;
    border-radius: 6px;
  }
</style>

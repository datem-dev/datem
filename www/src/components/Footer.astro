---
import Logo from './Logo.astro';
---
<footer class="footer">
  <div class="brand">
    <Logo size={17} strokeWidth={4.5} />
    datem
  </div>
  <div class="links">
    <a href="/docs/">docs</a><span>status</span><span>security</span><span>privacy</span><span>© 2026</span>
  </div>
</footer>

<style>
  .footer {
    padding: 30px 40px;
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--dm-font-mono);
    font-size: 12.5px;
    color: var(--dm-faint);
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 7px;
    font-weight: 600;
    color: var(--dm-ink);
    letter-spacing: -.04em;
  }
  .links { display: flex; gap: 22px; }
  .links a { color: inherit; text-decoration: none; }
</style>

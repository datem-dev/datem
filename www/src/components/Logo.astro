---
interface Props {
  size?: number;
  strokeWidth?: number;
}
const { size = 23, strokeWidth = 4 } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 64 64" fill="none">
  <line x1="6" y1="18" x2="30" y2="18" stroke="#14161A" stroke-width={strokeWidth} stroke-linecap="round"></line>
  <line x1="6" y1="32" x2="24" y2="32" stroke="#14161A" stroke-width={strokeWidth} stroke-linecap="round"></line>
  <line x1="6" y1="46" x2="30" y2="46" stroke="#14161A" stroke-width={strokeWidth} stroke-linecap="round"></line>
  <circle cx="42" cy="18" r="4" fill="#14161A"></circle>
  <circle cx="52" cy="32" r="6" fill="#C2461E"></circle>
  <circle cx="42" cy="46" r="4" fill="#14161A"></circle>
</svg>
